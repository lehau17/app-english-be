# ========================================
# Database Configuration
# ========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/english_learning

# ========================================
# JWT Configuration
# ========================================
JWT_SECRET=your-secret-key-here
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ========================================
# Kafka Configuration
# ========================================
KAFKA_BROKERS=localhost:19092

# ========================================
# SMTP Configuration (for notifications)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
FROM=noreply@example.com

# ========================================
# S3/MinIO Configuration
# ========================================
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio123
S3_BUCKET_NAME=english-learning-bucket

# ========================================
# API Configuration
# ========================================
CLIENT_API_PORT=3334
API_BASE_URL=http://localhost:3334

# ========================================
# Google Cloud Configuration for Google Translate API
# ========================================
# You need to set up a Google Cloud Project and enable the following APIs:
# - Cloud Translation API
# - Text-to-Speech API

# Your Google Cloud Project ID
GOOGLE_CLOUD_PROJECT_ID=your-project-id

# Path to your Google Cloud service account key file
# Download from: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_CLOUD_KEY_FILE=/path/to/your/service-account-key.json

# Alternative: Use base64 encoded key content
# GOOGLE_CLOUD_KEY_BASE64=your-base64-encoded-key

# API Keys (less secure, use service account instead)
# GOOGLE_TRANSLATE_API_KEY=your-api-key
# GOOGLE_TEXT_TO_SPEECH_API_KEY=your-api-key

# ========================================
# Gemini AI Configuration
# ========================================
GEMINI_API_KEY=your-gemini-api-key

# ========================================
# AI Speaking Configuration
# ========================================
# TTS (Text-to-Speech) Configuration
# Use HTTP API mode (recommended with Docker)
AI_SPEAKING_TTS_USE_HTTP=true
AI_SPEAKING_TTS_HTTP_URL=http://localhost:10200
AI_SPEAKING_TTS_VOICE=en_US-lessac-medium

# Alternative: Command-line mode (requires Piper installed locally)
# AI_SPEAKING_TTS_USE_HTTP=false
# AI_SPEAKING_TTS_COMMAND=piper
# AI_SPEAKING_TTS_MODEL_PATH=/path/to/model.onnx

# ASR (Automatic Speech Recognition) Configuration
AI_SPEAKING_ASR_WS_URL=ws://localhost:2700
AI_SPEAKING_ASR_AUDIO_FORMAT=pcm16
AI_SPEAKING_ASR_SAMPLE_RATE=16000

# Health Check Configuration
AI_SPEAKING_HEALTH_SKIP=false
AI_SPEAKING_HEALTH_TIMEOUT_MS=3000

# ========================================
# Neo4j Configuration (Graph RAG)
# ========================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-secure-password
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
