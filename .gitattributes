# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts should always use LF
*.sh text eol=lf

# Docker files
Dockerfile text eol=lf
docker-compose*.yml text eol=lf
.dockerignore text eol=lf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# Markdown files
*.md text eol=lf

# Scripts
Makefile text eol=lf
