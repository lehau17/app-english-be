// ===================== PRISMA SCHEMA — SINGLE FILE =====================

generator client {
    provider = "prisma-client-js"
    output   = "../../../node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ===================== ENUMS =====================

enum UserRole {
    student
    parent
    teacher
    admin
}

enum Status {
    active
    inactive
    banned
    pending
}

enum AuthProvider {
    local
    google
    facebook
    apple
}

enum Gender {
    male
    female
    other
}

enum LanguageCode {
    en
    vi
    ko
    jp
    zh
    fr
}

enum TimezoneCode {
    Asia_Ho_Chi_Minh
    Asia_Tokyo
    Asia_Seoul
    America_New_York
    Europe_London
}

enum ActivityType {
    vocab
    pronunciation
    listening
    speaking
    mini_game
}

enum ProgressState {
    not_started
    in_progress
    done
}

// -------- B2C extras --------
enum DevicePlatform {
    ios
    android
    web
}

enum NotificationChannel {
    socket
    fcm
}

// ===================== MODELS =====================

model User {
    id            String        @id @default(uuid())
    email         String?       @unique
    phone         String?       @unique
    username      String?       @unique
    passwordHash  String?
    role          UserRole      @default(student)
    status        Status        @default(active)
    provider      AuthProvider  @default(local)
    providerId    String?
    firstName     String?
    lastName      String?
    gender        Gender?
    dob           DateTime?
    avatarUrl     String?
    bio           String?
    language      LanguageCode?
    timezone      TimezoneCode?
    lastLoginAt   DateTime?
    lastActiveAt  DateTime?
    emailVerified Boolean       @default(false)
    phoneVerified Boolean       @default(false)
    preferences   Json?
    createdAt     DateTime      @default(now())
    updatedAt     DateTime      @updatedAt

    Profile      Profile?
    Progress     Progress[]
    Attempts     Attempt[]
    RefreshToken RefreshToken[]

    // B2C extras relations
    DeviceTokens     DeviceToken[]
    Notifications    Notification[]
    UserStats        UserStats?
    UserBadges       UserBadge[] // badges earned
    // ParentChild relations are defined in ParentChild model via named relations
    parentRelations  ParentChild[]      @relation("ParentChildParent")
    childRelations   ParentChild[]      @relation("ParentChildChild")
    LeaderboardEntry LeaderboardEntry[]

    @@index([status])
    @@index([provider, providerId])
    @@index([lastActiveAt])
}

model RefreshToken {
    id        String    @id
    userId    String
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    expiresAt DateTime
    createdAt DateTime  @default(now())
    revokedAt DateTime?

    @@index([userId])
}

model Profile {
    id          String    @id @default(uuid())
    userId      String    @unique
    displayName String?
    avatarUrl   String?
    dob         DateTime?
    guardianId  String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
    id          String  @id @default(uuid())
    title       String
    description String?
    orderNo     Int

    lessons Lesson[]

    @@unique([orderNo])
    @@index([orderNo])
}

model Lesson {
    id          String  @id @default(uuid())
    courseId    String
    title       String
    description String?
    orderNo     Int

    course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
    activities Activity[]

    @@unique([courseId, orderNo])
    @@index([courseId, orderNo])
}

model Activity {
    id       String       @id @default(uuid())
    lessonId String
    type     ActivityType
    orderNo  Int
    content  Json

    lesson   Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
    progress Progress[]
    attempts Attempt[]

    @@unique([lessonId, orderNo])
    @@index([lessonId, orderNo])
}

model Progress {
    id           String        @id @default(uuid())
    userId       String
    activityId   String
    state        ProgressState @default(not_started)
    score        Int?
    timeSpentSec Int           @default(0)
    updatedAt    DateTime      @default(now())

    user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

    @@unique([userId, activityId])
    @@index([userId, updatedAt])
}

model Attempt {
    id         String   @id @default(uuid())
    userId     String
    activityId String
    score      Int?
    detail     Json?
    createdAt  DateTime @default(now())

    user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

    @@index([userId, createdAt])
}

// ===================== B2C EXTRAS (PARENT, NOTIFICATIONS, GAMIFICATION) =====================

model ParentChild {
    parentId  String
    childId   String
    createdAt DateTime @default(now())

    parent User @relation("ParentChildParent", fields: [parentId], references: [id], onDelete: Cascade)
    child  User @relation("ParentChildChild", fields: [childId], references: [id], onDelete: Cascade)

    @@id([parentId, childId])
    @@index([childId])
}

model DeviceToken {
    id         String         @id @default(uuid())
    userId     String
    token      String         @unique
    platform   DevicePlatform
    lastSeenAt DateTime?
    createdAt  DateTime       @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, platform])
}

model Notification {
    id        String              @id @default(uuid())
    userId    String
    title     String
    body      String?
    data      Json?
    channel   NotificationChannel
    readAt    DateTime?
    createdAt DateTime            @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, createdAt])
}

model UserStats {
    userId       String    @id
    xp           Int       @default(0)
    streakDays   Int       @default(0)
    lastStreakAt DateTime?
    updatedAt    DateTime  @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
    id          String      @id @default(uuid())
    code        String      @unique
    name        String
    description String?
    iconUrl     String?
    UserBadge   UserBadge[]
}

model UserBadge {
    userId   String
    badgeId  String
    earnedAt DateTime @default(now())

    user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
    badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

    @@id([userId, badgeId])
    @@index([badgeId])
}

model LeaderboardEntry {
    id          String   @id @default(uuid())
    periodStart DateTime
    periodEnd   DateTime
    userId      String
    xp          Int      @default(0)
    rank        Int?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, periodStart, periodEnd])
    @@index([periodStart, periodEnd, xp])
}
