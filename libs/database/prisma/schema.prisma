    @@index([startDate, endDate])
}

model ChallengeParticipation {
    challengeId String
    userId      String
    progress    Int       @default(0)
    completed   Boolean   @default(false)
    completedAt DateTime?

    challenge GroupChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

    @@id([challengeId, userId])
    @@index([userId])
}

// ===================== COMMUNICATION =====================

model Message {
    id         String @id @default(uuid())
    fromUserId String
    toUserId   String
    content    String
    type       String @default("text")

    // Message metadata
    mediaUrl String?
    isRead   Boolean   @default(false)
    readAt   DateTime?

    // Parent-child communication
    isParentChild Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    fromUser User @relation("MessageFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
    toUser   User @relation("MessageTo", fields: [toUserId], references: [id], onDelete: Cascade)

    @@index([fromUserId])
    @@index([toUserId])
    @@index([createdAt])
    @@index([isParentChild])
}

model Conversation {
    id           String   @id @default(uuid())
    participants String[]
    type         String   @default("direct")
    name         String?

    // Last message info
    lastMessageAt DateTime?
    lastMessage   String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([participants])
    @@index([lastMessageAt])
}

// ===================== CONTENT MANAGEMENT =====================

model Content {
    id          String  @id @default(uuid())
    type        String
    title       String
    description String?

    // Content data
    data       Json
    mediaFiles Json?
    metadata   Json?

    // Publishing
    status     ContentStatus @default(draft)
    creatorId  String
    reviewerId String?

    // Organization
    tags       String[]
    categories String[]
    difficulty DifficultyLevel @default(beginner)
    language   LanguageCode    @default(en)

    // Usage tracking
    usageCount Int    @default(0)
    rating     Float?

    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    publishedAt DateTime?

    creator User @relation("ContentCreator", fields: [creatorId], references: [id], onDelete: Cascade)

    @@index([status])
    @@index([creatorId])
    @@index([type])
    @@index([difficulty])
    @@index([tags])
}

model MediaFile {
    id           String  @id @default(uuid())
    filename     String
    originalName String
    mimeType     String
    size         Int
    url          String
    thumbnail    String?

    // Processing status for audio/video
    isProcessed Boolean @default(false)
    duration    Int?

    // Usage tracking
    usageCount Int @default(0)

    createdAt DateTime @default(now())

    @@index([mimeType])
    @@index([isProcessed])
}

model Vocabulary {
    id            String  @id @default(uuid())
    word          String  @unique
    definition    String
    pronunciation String?
    audioUrl      String?
    imageUrl      String?

    // Learning data
