  @@index([turnId, orderNo])
  @@map("ai_speaking_turn_segments")
}

// ===================== PODCAST & LISTENING PRACTICE SYSTEM =====================

enum PodcastStatus {
  draft

  published

  archived

  scheduled
}

enum PodcastCategory {
  study_abroad @map("Du học")

  business @map("Kinh doanh")

  technology @map("Công nghệ")

  lifestyle @map("Lối sống")

  entertainment @map("Giải trí")

  education @map("Giáo dục")

  news @map("Tin tức")

  culture @map("Văn hóa")

  science @map("Khoa học")

  travel @map("Du lịch")
}

enum PodcastSource {
  wele_partners @map("WELE Partners")

  ted_talks @map("TED Talks")

  bbc @map("BBC")

  cnn @map("CNN")

  voice_of_america @map("Voice of America")

  british_council @map("British Council")

  internal @map("Nội bộ")
}

enum PodcastDifficulty {
  beginner @map("Người mới bắt đầu")

  elementary @map("Sơ cấp")

  intermediate @map("Trung cấp")

  upper_intermediate @map("Trung cấp cao")

  advanced @map("Nâng cao")
}

enum ListeningActivityType {
  fill_blank @map("Điền vào chỗ trống")
}

// ===================== CORE PODCAST MODELS =====================

model Podcast {
  id String @id @default(uuid())

  code String @unique

  title String

  description String

  // Media files - Support both audio and video

  audioUrl String? // Optional now - for audio podcasts

  videoUrl String? // New - for video podcasts

  mediaType String @default("audio") // "audio" | "video"

  thumbnailUrl String?

  // Transcript & Test

  transcript String @db.Text // Toàn bộ transcript gốc

  gaps PodcastGap[] // Danh sách chỗ đục lỗ (bài kiểm)

  averageRating Float? @default(0)

  difficultyRating Float? @default(0)

  qualityRating Float? @default(0)

  totalRatings Int @default(0)

  // Metadata

  category PodcastCategory

  difficulty PodcastDifficulty @default(intermediate)

  duration Int // seconds

  viewCount Int @default(0)

  authorId String

  author User? @relation("PodcastAuthor", fields: [authorId], references: [id])

  isPublic Boolean @default(true)

  playlistPodcasts PlaylistPodcast[]

  // Ratings & Comments

  ratings PodcastRating[]

  comments PodcastComment[]

  // Attempts (bài làm)

  attempts PodcastAttempt[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@map("podcasts")
}

// ===================== GAP (Blank trong transcript) =====================

model PodcastGap {
  id String @id @default(uuid())

  podcastId String

  startIndex Int // Vị trí ký tự bắt đầu trong transcript

  endIndex Int // Vị trí ký tự kết thúc trong transcript

  answer String // Đáp án đúng (từ/cụm từ bị che)

  orderNo Int @default(1)

  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@index([podcastId])
  @@map("podcast_gaps")
}

// ===================== SIMPLIFIED ATTEMPT MODEL =====================

model PodcastAttempt {
  id String @id @default(uuid())

  userId String

  podcastId String

  attemptNo Int @default(1) // Có thể làm nhiều lần

  // Simplified scoring: count correct answers and calculate percentage

  correctCount Int @default(0)

  totalQuestions Int @default(0)

  scorePercent Float @default(0) // 0-100 percentage

  // Performance tracking

  timeSpent Int? // seconds

  answers Json // User's answers: { "q1": "answer1", "q2": "answer2", ... }

  status AttemptStatus @default(in_progress)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations

  user User @relation("UserPodcastAttempts", fields: [userId], references: [id], onDelete: Cascade)

  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@unique([userId, podcastId, attemptNo])
  @@index([userId, createdAt])
  @@index([podcastId])
  @@map("podcast_attempts")
}

// ===================== USER PODCAST PROGRESS =====================

// ===================== RATING & FEEDBACK =====================

model PodcastRating {
  id String @id @default(uuid())

  userId String

  podcastId String

  // Ratings (1-5 scale)

  overallRating Int // Tổng thể

  difficultyRating Int // Độ khó (1=easy, 5=very hard)

  qualityRating Int // Chất lượng (1=poor, 5=excellent)

  contentRating Int? // Nội dung

  audioRating Int? // Chất lượng âm thanh

  // Review

  title String?

  comment String?

  pros String[] @default([])

  cons String[] @default([])

  // Verification

  isVerified Boolean @default(false)

  isModerated Boolean @default(false)

  // Helpful votes

  helpfulCount Int @default(0)

  unhelpfulCount Int @default(0)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  // Relations

  user User @relation("UserPodcastRatings", fields: [userId], references: [id], onDelete: Cascade)

  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@unique([userId, podcastId])
  @@index([podcastId, overallRating])
  @@index([createdAt])
  @@map("podcast_ratings")
}

model PodcastComment {
  id String @id @default(uuid())

  userId String

  podcastId String

  parentId String? // For replies

  content String

  isEdited Boolean @default(false)

  isReported Boolean @default(false)

  isModerated Boolean @default(false)

  // Engagement

  likeCount Int @default(0)

  replyCount Int @default(0)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  // Relations

  user User @relation("UserPodcastComments", fields: [userId], references: [id], onDelete: Cascade)

  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  parent PodcastComment? @relation("CommentReplies", fields: [parentId], references: [id])

  replies PodcastComment[] @relation("CommentReplies")

  @@index([podcastId, createdAt])
  @@index([userId])
  @@index([parentId])
  @@map("podcast_comments")
}

// ===================== PLAYLIST SYSTEM =====================

model Playlist {
  id String @id @default(uuid())

  userId String

  name String

  description String?

  isPublic Boolean @default(false)

  isSystem Boolean @default(false) // For auto-generated playlists

  // Metadata

  thumbnailUrl String?

  tags String[] @default([])

  category String?

  // Stats

  podcastCount Int @default(0)

  totalDuration Int @default(0) // seconds

  playCount Int @default(0)

  likeCount Int @default(0)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  // Relations

  user User @relation("UserPlaylists", fields: [userId], references: [id], onDelete: Cascade)

  playlistPodcasts PlaylistPodcast[]

  @@index([userId])
  @@index([isPublic])
  @@map("playlists")
}

model PlaylistPodcast {
  playlistId String

  podcastId String

  orderNo Int @default(1)

  addedAt DateTime @default(now())

  // Relations

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@id([playlistId, podcastId])
  @@index([playlistId, orderNo])
  @@map("playlist_podcasts")
}

// ===================== ANALYTICS & TRACKING =====================

model PodcastAnalytics {
  id String @id @default(uuid())

  podcastId String

  date DateTime @default(now())

  // Metrics

  views Int @default(0)

  uniqueViews Int @default(0)

  completions Int @default(0)

  likes Int @default(0)

  saves Int @default(0)

  shares Int @default(0)

  comments Int @default(0)

  // Engagement

  avgWatchTime Float? // seconds

  bounceRate Float? // percentage

  retentionRate Float? // percentage

  // Traffic sources

  sourceData Json?

  createdAt DateTime @default(now())

  @@unique([podcastId, date])
  @@index([podcastId])
  @@index([date])
  @@map("podcast_analytics")
}

// ===================== PAYMENT SYSTEM =====================

model Transaction {
  id String @id @default(uuid())

  // Basic info
  amount   Float
  currency String          @default("VND")
  type     TransactionType @default(course_purchase)

  // Payment info
  provider PaymentProvider @default(vnpay)
  status   PaymentStatus   @default(pending)

  // VNPay specific
  vnpayTransactionNo String? // vnp_TransactionNo
  vnpayTxnRef        String? // vnp_TxnRef (order ID)
  vnpayResponseCode  String? // vnp_ResponseCode
  vnpaySecureHash    String? // vnp_SecureHash

  // Relations
  studentId   String? // Optional cho guest enrollment (User ch\u01b0a t\u1ed3n t\u1ea1i)
  courseId    String?
  classroomId String?

  // Metadata
  description String?
  returnUrl   String?
  ipAddress   String?

  // Response data from VNPay
  responseData Json? // Full response từ VNPay (+ enrollmentMetadata cho guest)

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime? // Khi thanh toán thành công

  // Relations
  student   User?      @relation("StudentTransactions", fields: [studentId], references: [id], onDelete: Cascade)
  course    Course?    @relation("CourseTransactions", fields: [courseId], references: [id], onDelete: SetNull)
  classroom Classroom? @relation("ClassroomTransactions", fields: [classroomId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([courseId])
  @@index([classroomId])
  @@index([status])
  @@index([vnpayTxnRef])
  @@index([createdAt])
}

// ===================== AGENT CHAT =====================

model AgentConversation {
  id     String  @id @default(uuid())
  userId String? // Optional for guest users

  role String @default("guest") // 'guest' | 'student' | 'parent' | 'teacher' | 'admin'

  guestSessionId String? // UUID from localStorage for guest tracking

  title    String?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?          @relation("AgentConversations", fields: [userId], references: [id], onDelete: Cascade)
  messages AgentMessage[]

  @@index([userId])
  @@index([guestSessionId])
  @@index([createdAt])
  @@index([role])
  @@index([userId, role])
}

model AgentMessage {
  id             String @id @default(uuid())
  conversationId String
  role           String // 'user' or 'assistant'
  content        String @db.Text

  metadata Json?

  createdAt DateTime @default(now())

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

// ===================== VOCABULARY BOOK =====================

model SavedWord {
  id        String   @id @default(cuid())
  word      String
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, word])
  @@index([userId])
  @@map("saved_words")
}

// ===================== CERTIFICATE SYSTEM =====================

enum CertificateRequirementType {
  course_completion // Hoàn thành course
  score_based // Dựa trên điểm số
  combined // Kết hợp cả 2

  @@map("CertificateRequirementType")
}

enum LinkRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED

  @@map("LinkRequestStatus")
}

enum LinkInitiatedBy {
  STUDENT
  PARENT
  ADMIN

  @@map("LinkInitiatedBy")
}

// Template chứng chỉ cho mỗi course
model CertificateTemplate {
  id       String @id @default(uuid())
  courseId String @unique // 1-1 relationship with Course

  // Template Design
  title       String  @default("Certificate of Completion")
  description String? @db.Text

  // Design Layout (JSON)
  layout Json? @db.JsonB

  // Template Fields
  issuerName      String  @default("English Learning Platform")
  issuerTitle     String? @default("Director of Education")
  issuerSignature String?
  logoUrl         String?

  // Requirements
  requirementType CertificateRequirementType @default(course_completion)
  minScore        Float?
  minProgress     Float                      @default(100)

  // Metadata
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  course       Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  certificates IssuedCertificate[]

  @@index([courseId])
  @@map("certificate_templates")
}

// Certificate đã cấp
model IssuedCertificate {
  id                String @id @default(uuid())
  certificateNumber String @unique

  // Relations
  templateId  String
  studentId   String
  courseId    String
  classroomId String?

  // Student Info (snapshot)
  studentName  String
  studentEmail String

  // Course Info (snapshot)
  courseName        String
  courseDescription String?

  // Achievement Data
  completionDate DateTime @default(now())
  finalScore     Float?
  gradeLevel     String? // 'Xuất sắc' | 'Giỏi' | 'Khá' | 'Trung bình' | 'Yếu'
  progress       Float    @default(100)
  totalHours     Float?

  // Certificate Data
  issueDate  DateTime  @default(now())
  expiryDate DateTime?

  // Verification
  verificationCode String    @unique
  verifiedAt       DateTime?

  // Status
  isRevoked     Boolean   @default(false)
  revokedAt     DateTime?
  revokedReason String?

  // Metadata
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  template  CertificateTemplate @relation(fields: [templateId], references: [id])
  student   User                @relation("UserCertificates", fields: [studentId], references: [id])
  course    Course              @relation(fields: [courseId], references: [id])
  classroom Classroom?          @relation(fields: [classroomId], references: [id])

  @@index([studentId])
  @@index([courseId])
  @@index([certificateNumber])
  @@index([verificationCode])
  @@index([completionDate])
  @@map("issued_certificates")
}
