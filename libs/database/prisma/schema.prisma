model StudyGroupMember {
    groupId  String
    userId   String
    role     String   @default("member")
    joinedAt DateTime @default(now())
    isActive Boolean  @default(true)

    group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

    @@id([groupId, userId])
