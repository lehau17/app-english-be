// ===================== PRISMA SCHEMA — ENHANCED VERSION =====================

generator client {
  provider = "prisma-client-js"

  output = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== ENUMS =====================

enum UserRole {
  student @map("STUDENT")

  parent @map("PARENT")

  teacher @map("TEACHER")

  admin @map("ADMIN")

  content_creator @map("CONTENT_CREATOR")

  @@map("UserRole")
}

