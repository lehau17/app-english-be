// ===================== MODELS =====================

model KnowledgeDocument {
  id String @id @default(uuid())

  title String

  content String

  embedding String

  /// pgvector column to store embedding vector for ANN queries
  embeddingVector Unsupported("vector")? @map("embedding_vector")

  /// Full-text search column (tsvector) - auto-generated by trigger
  contentSearch Unsupported("tsvector")? @map("content_search")

  documentType String

  source String

  createdAt DateTime @default(now())

  // ============ Document Chunking Support ============
  /// Parent document ID for chunks (null for root documents)
  parentId String? @map("parent_id")

  /// Position of this chunk within parent (0, 1, 2, ...) - null for root documents
  chunkIndex Int? @map("chunk_index")

  /// Total number of chunks in parent document (only set on root documents)
  totalChunks Int? @default(0) @map("total_chunks")

  /// Is this a chunk or a root document?
  isChunk Boolean @default(false) @map("is_chunk")

  // Self-referential relationship for parent-child chunks
  parent KnowledgeDocument?  @relation("DocumentChunks", fields: [parentId], references: [id], onDelete: Cascade)
  chunks KnowledgeDocument[] @relation("DocumentChunks")

  @@index([parentId])
  @@index([isChunk])
  @@index([parentId, chunkIndex])
  @@map("knowledge_documents")
}

model User {
  id String @id @default(uuid())

  email String? @unique

  phone String? @unique

  passwordHash String?

  role UserRole @default(student)

  status Status @default(active)

  provider AuthProvider @default(local)

  providerId String?

  // Thông tin cá nhân chi tiết

  firstName String?

  lastName String?

  displayName String?

  gender Gender?

  dob DateTime?

  nationality String?

  nativeLanguage LanguageCode?

  avatarUrl String?

  bio String?

  // Thông tin giáo viên
  experience Int? // Số năm kinh nghiệm (dành cho giáo viên)
  highlights String[] // Các điểm nổi bật (dành cho giáo viên)

  // Cài đặt hệ thống

  language LanguageCode @default(en)

  timezone TimezoneCode? @default(Asia_Ho_Chi_Minh)

  // Thông tin xác thực

  lastLoginAt DateTime?

  lastActiveAt DateTime?

  emailVerified Boolean @default(false)

  phoneVerified Boolean @default(false)

  twoFactorEnabled Boolean @default(false)

  // Cài đặt và tùy chọn

  preferences Json?

  privacySettings Json?

  notificationSettings Json?

  parentalConsent Boolean?

  // Metadata

  profileCompleteness Int @default(0)

  isOnline Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  // Relations

  Profile Profile?

  Progress Progress[]

  Attempts Attempt[]

  RefreshToken        RefreshToken[]
  PasswordResetTokens PasswordResetToken[]

  DeviceTokens DeviceToken[]

  Notifications Notification[]

  // Parent-Child relations

  parentRelations ParentChild[] @relation("ParentChildParent")

  childRelations ParentChild[] @relation("ParentChildChild")

  parentLinkRequests   ParentChildLinkRequest[] @relation("ParentLinkRequests")
  studentLinkRequests  ParentChildLinkRequest[] @relation("StudentLinkRequests")
  resolvedLinkRequests ParentChildLinkRequest[] @relation("ResolvedLinkRequests")

  // Course and Class relations

  coursesCreated Course[] @relation("CourseInstructor")

  // Teacher-Student relations

  classroomsTeaching Classroom[] @relation("TeacherClassrooms")

  classroomsSessions ClassroomSession[]

  sessionAttendance SessionAttendance[]

  // Makeup attendance requests
  studentMakeupRequests  MakeupAttendanceRequest[] @relation("StudentMakeupRequests")
  reviewedMakeupRequests MakeupAttendanceRequest[] @relation("ReviewedMakeupRequests")

  // Session reschedule requests
  requestedReschedules SessionRescheduleRequest[] @relation("RequestedReschedules")
  reviewedReschedules  SessionRescheduleRequest[] @relation("ReviewedReschedules")

  classroomsStudying ClassroomStudent[]

  assignmentsCreated Assignment[] @relation("TeacherAssignments")

  assignmentSubmissions AssignmentSubmission[]

  gradedSubmissions AssignmentSubmission[] @relation("GradedSubmissions")

  // Communication

  conversationsCreated Conversation[] @relation("ConversationCreator")

  conversationLastMessage Conversation[] @relation("ConversationLastMessageSender")

  conversationParticipants ConversationParticipant[]

  messagesSent Message[] @relation("MessageSender")

  // Custom content

  createdContent Content[] @relation("ContentCreator")

  // Rewards and achievements

  customRewards CustomReward[] @relation("ParentRewards")

  rewardClaims RewardClaim[]

  // Security

  securityLogs SecurityLog[]

  loginSessions LoginSession[]

  // Podcast & Listening Practice

  podcastsCreated Podcast[] @relation("PodcastAuthor")

  podcastAttempts PodcastAttempt[] @relation("UserPodcastAttempts")

  podcastRatings PodcastRating[] @relation("UserPodcastRatings")

  // Certificates
  certificates IssuedCertificate[] @relation("UserCertificates")

  podcastComments PodcastComment[] @relation("UserPodcastComments")

  playlists Playlist[] @relation("UserPlaylists")

  aiSpeakingSessions AiSpeakingSession[]

  leaderboardSnapshots LeaderboardSnapshot[]

  // Payment transactions
  transactions Transaction[] @relation("StudentTransactions")

  // Agent conversations
  agentConversations AgentConversation[] @relation("AgentConversations")

  savedWords SavedWord[]

  // Vocabulary system
  createdVocabLists   VocabularyList[]          @relation("VocabularyListCreator")
  addedVocabLists     UserVocabularyList[]
  vocabularyProgress  UserVocabularyProgress[]
  vocabReviewSessions VocabularyReviewSession[]

  @@index([status])
  @@index([provider, providerId])
  @@index([lastActiveAt])
  @@index([role])
  @@index([email])
  @@index([phone])
}

model Course {
  id String @id @default(uuid())

  title String

  description String?

  orderNo Int?

  difficulty DifficultyLevel @default(beginner)

  estimatedHours Float? // Tổng giờ ước tính để hoàn tất course (tính bằng giờ)

  imageUrl String?

  tags String[]

  isPublished Boolean @default(false)

  prerequisites String[]

  // Details

  instructorId String

  price Float? @default(0)

  currency String? @default("VND")

  maxStudents Int? @default(20)

  language LanguageCode @default(vi)

  // Số buổi học (thêm mới)
  plannedSessions Int? @default(8) // Số buổi học dự kiến

  // Content metrics (tùy chọn)

  totalLessons Int? @default(0)

  totalDuration Int? @default(0) // phút

  // Default assignment weights for gradebook calculation
  // Format: { midterm: 0.3, final: 0.4, tests: 0.2, activities: 0.1 }
  defaultAssignmentWeights Json?

  // Meta

  rating Float?

  totalRatings Int @default(0)

  enrollmentCount Int @default(0)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  // Relations

  instructor User @relation("CourseInstructor", fields: [instructorId], references: [id], onDelete: Cascade)

  lessons Lesson[]

  courseRatings CourseRating[]

  classrooms Classroom[] // 1 course → nhiều classroom

  // Lộ trình buổi học
  sessionSchedules SessionSchedule[]

  // Payment transactions
  transactions Transaction[] @relation("CourseTransactions")

  // Certificate
  certificateTemplate CertificateTemplate?
  issuedCertificates  IssuedCertificate[]

  @@index([instructorId])
  @@index([orderNo])
  @@index([difficulty])
  @@index([isPublished])
  @@index([price])
}

model Room {
  id String @id @default(uuid())

  name String

  code String @unique // VD: A101, B205

  location String?

  capacity Int @default(30)

  description String?

  equipment Json?

  facilities Json?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
}

// ===================== ORIGINAL MODELS (MODIFIED) =====================

model CourseRating {
  id String @id @default(uuid())

  courseId String

  userId String

  rating Int // 1-5 sao

  comment String?

  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId])
}

model Lesson {
  id String @id @default(uuid())

  courseId String

  title String

  description String?

  orderNo Int

  difficulty DifficultyLevel @default(beginner)

  estimatedTime Int?

  isLocked Boolean @default(true)

  objectives String[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  activities Activity[]

  lessonDetails LessonDetail[]

  @@unique([courseId, orderNo])
  @@index([courseId, orderNo])
  @@index([isLocked])
}

model LessonDetail {
  id String @id @default(uuid())

  lessonId String

  type String

  content Json

  orderNo Int

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([lessonId, orderNo])
}

model Activity {
  id String @id @default(uuid())

  lessonId String

  type ActivityType

  orderNo Int

  title String

  // === Nguồn sự thật cho mọi loại activity ===

  // Lưu JSONB (Postgres): payload phụ thuộc 'type'

  content Json

  // Cấu hình chung

  passingScore Int?

  difficulty DifficultyLevel @default(beginner)

  points Int @default(10)

  // Metadata nhẹ (tùy chọn)

  instructions String?

  hints String[] @default([]) // gọn hơn Json? khi chỉ là list text

  mediaUrls String[] @default([]) // dùng text[] nếu chỉ URL

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  // Relations

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  progress Progress[]

  attempts Attempt[]

  // Quan hệ với lộ trình buổi học
  sessionActivities SessionActivity[]

  @@unique([lessonId, orderNo])
  @@index([lessonId, orderNo])
  @@index([type])
  @@index([difficulty])
}

model Question {
  id String @id @default(uuid())

  activityId String

  type QuestionType

  question String

  options Json?

  correctAnswer String

  explanation String?

  points Int @default(1)

  orderNo Int

  mediaUrl String?

  @@index([activityId])
  @@index([activityId, orderNo])
}

// ===================== COURSE SESSION SCHEDULE =====================

model SessionSchedule {
  id String @id @default(uuid())

  courseId String

  sessionNumber Int // Số thứ tự buổi học (1, 2, 3, ...)

  title String? // Tiêu đề buổi học (có thể để trống)

  description String? // Mô tả ngắn

  // Tham chiếu tới Course
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // Mối quan hệ với Activity
  activities SessionActivity[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([courseId, sessionNumber]) // Mỗi buổi học phải có số thứ tự duy nhất trong khóa học
  @@index([courseId])
}

model SessionActivity {
  id String @id @default(uuid())

  sessionScheduleId String

  activityId String

  orderNo Int // Thứ tự trong buổi học

  // Tham chiếu
  sessionSchedule SessionSchedule @relation(fields: [sessionScheduleId], references: [id], onDelete: Cascade)
  activity        Activity        @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([sessionScheduleId, orderNo]) // Đảm bảo thứ tự các hoạt động trong buổi học là duy nhất
  @@index([sessionScheduleId])
  @@index([activityId])
}

// ===================== ORIGINAL MODELS (UNCHANGED) =====================

model RefreshToken {
  id String @id

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceId String?

  expiresAt DateTime

  createdAt DateTime @default(now())

  revokedAt DateTime?

  lastUsedAt DateTime?

  @@index([userId])
  @@index([deviceId])
}

model LoginSession {
  id String @id @default(uuid())

  userId String

  deviceInfo Json?

  ipAddress String?

  location String?

  userAgent String?

  isActive Boolean @default(true)

  expiresAt DateTime

  createdAt DateTime @default(now())

  lastActiveAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
}

model SecurityLog {
  id String @id @default(uuid())

  userId String

  action String

  ipAddress String?

  userAgent String?

  location String?

  metadata Json?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Profile {
  id String @id @default(uuid())

  userId String @unique

  displayName String?

  avatarUrl String?

  dob DateTime?

  guardianId String?

  // Thông tin học tập

  currentLevel String?

  learningGoals Json?

  studyStreak Int @default(0)

  totalStudyTime Int @default(0)

  // Cài đặt học tập cá nhân

  dailyGoalMinutes Int?

  reminderTimes Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id String @id @default(uuid())

  userId String

  tokenHash String

  expiresAt DateTime

  usedAt DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Progress {
  id String @id @default(uuid())

  userId String

  activityId String

  state ProgressState @default(not_started)

  score Int?

  bestScore Int?

  timeSpentSec Int @default(0)

  attemptsCount Int @default(0)

  // Chi tiết tiến trình

  lastQuestionIndex Int?

  strengths Json?

  weaknesses Json?

  createdAt DateTime @default(now())

  updatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
  @@index([userId, updatedAt])
  @@index([state])
}

model Attempt {
  id String @id @default(uuid())

  userId String

  activityId String

  score Int?

  maxScore Int?

  timeSpent Int?

  detail Json?

  feedback String?

  // Phân tích chi tiết

  correctAnswers Int?

  totalQuestions Int?

  averageTime Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([activityId])
}

// ===================== CLASSROOM (COHORT) =====================

model Classroom {
  id String @id @default(uuid())

  courseId String

  teacherId String

  name String

  description String?

  classCode String @unique

  isActive Boolean @default(true)

  maxStudents Int?

  // Trạng thái lớp học
  status ClassroomStatus @default(upcoming)

  // Thông tin thời gian của CẢ LỚP (khung chạy của cohort)

  periodStart DateTime // Ngày bắt đầu lớp (theo lịch)

  periodEnd DateTime // Ngày kết thúc lớp (theo lịch)

  timezone TimezoneCode @default(Asia_Ho_Chi_Minh)

  // Quy mô giờ học của lớp (tự động tính từ slots và period)

  plannedHours Float? // Tổng SỐ GIỜ học - tự động tính từ slots và khoảng thời gian

  plannedSessions Int? // Số buổi dự kiến - tự động tính từ slots và period

  // Cài đặt khác

  settings Json?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  expiresAt DateTime?

  // Relations

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  teacher User @relation("TeacherClassrooms", fields: [teacherId], references: [id], onDelete: Cascade)

  students ClassroomStudent[]

  assignments Assignment[]

  announcements Announcement[]

  slots ClassroomSlot[] // Weekly schedule pattern

  sessions      ClassroomSession[] // Generated sessions from pattern or manual creation
  conversations Conversation[]

  leaderboardSnapshots LeaderboardSnapshot[]

  // Payment transactions
  transactions Transaction[] @relation("ClassroomTransactions")

  // Certificates
  certificates IssuedCertificate[]

  // Learning paths
  learningPaths LearningPath[]

  @@index([courseId])
  @@index([teacherId])
  @@index([classCode])
  @@index([isActive])
  @@index([status])
  @@index([periodStart])
  @@index([periodEnd])
}

// ===================== WEEKLY SLOTS (KHUNG GIỜ) =====================

// Mỗi slot = 1 ca cố định trong tuần (VD: Tue 18:30-20:00)

// Lưu giờ theo phút từ 00:00 để không cần kiểu TIME

model ClassroomSlot {
  id String @id @default(uuid())

  classroomId String

  dayOfWeek Weekday

  startMinuteOfDay Int // ví dụ 18:30 -> 18*60+30 = 1110

  endMinuteOfDay Int // ví dụ 20:00 -> 1200

  isActive Boolean @default(true)

  // Duration tính từ startMinuteOfDay và endMinuteOfDay

  // sessionDurationHours Float? // REMOVED - tính trực tiếp từ start/end minutes

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@index([classroomId])
  @@index([dayOfWeek])
}

// ===================== CLASSROOM SESSIONS (BUỔI HỌC) =====================

model ClassroomSession {
  id String @id @default(uuid())

  classroomId String

  instructorId String

  title String

  description String?

  // Thời điểm thực tế của buổi (UTC)

  startTime DateTime

  endTime DateTime

  timezone TimezoneCode @default(Asia_Ho_Chi_Minh)

  // Thời lượng buổi (giờ) – thực tế, có thể khác pattern nếu dời lịch

  durationHours Float

  // Hình thức

  type SessionType @default(offline)

  status SessionStatus @default(scheduled)

  meetingUrl String?

  // Nội dung

  agenda    Json?
  materials Json?

  // Meta

  notes String?

  recordingUrl String?

  // Store course session schedule info and activities for this session
  metadata Json?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  // Relations

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  instructor User @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  attendance SessionAttendance[]

  makeupRequests MakeupAttendanceRequest[]

  rescheduleRequests SessionRescheduleRequest[] @relation("SessionRescheduleRequests")

  @@index([classroomId])
  @@index([instructorId])
  @@index([startTime])
  @@index([endTime])
}

model SessionAttendance {
  id String @id @default(uuid())

  sessionId String

  studentId String

  status String @default("present") // present, absent, late, excused

  checkInTime DateTime?

  checkOutTime DateTime?

  notes String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  session ClassroomSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
  @@index([status])
}

model MakeupAttendanceRequest {
  id           String              @id @default(uuid())
  sessionId    String
  studentId    String
  reason       String // Lý do xin điểm danh bù
  evidenceUrls String[] // URLs của minh chứng (ảnh, file...)
  status       MakeupRequestStatus @default(pending)

  // Review info
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String? // Ghi chú của reviewer

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session    ClassroomSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student    User             @relation("StudentMakeupRequests", fields: [studentId], references: [id], onDelete: Cascade)
