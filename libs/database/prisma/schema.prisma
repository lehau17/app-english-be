// ===================== PRISMA SCHEMA — ENHANCED VERSION =====================

generator client {
    provider = "prisma-client-js"
    output   = "../../../node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ===================== ENUMS =====================

enum UserRole {
  student         @map("STUDENT")
  parent          @map("PARENT")
  teacher         @map("TEACHER")
  admin           @map("ADMIN")
  content_creator @map("CONTENT_CREATOR")
  @@map("UserRole")
}

enum Status {
    active
    inactive
    banned
    pending
    suspended
}


enum SessionStatus {
  scheduled
  ongoing
  completed
  cancelled
  postponed
}

enum SessionType {
  online
  offline
  hybrid
}


enum Weekday {
  mon
  tue
  wed
  thu
  fri
  sat
  sun
}

enum AuthProvider {
    local
    google
    facebook
    apple
}

enum Gender {
    male
    female
    other
    prefer_not_to_say
}

enum LanguageCode {
    en
    vi
    ko
    jp
    zh
    fr
    es
    de
}

enum TimezoneCode {
    Asia_Ho_Chi_Minh
    Asia_Tokyo
    Asia_Seoul
    America_New_York
    Europe_London
    America_Los_Angeles
    Australia_Sydney
}

enum ActivityType {
  vocab
  pronunciation
  listening
  speaking
  mini_game
    fill_blank
    dictation
    matching
  reading
  writing
  grammar
  quiz
  flashcard
  conversation
}


enum ProgressState {
    not_started
    in_progress
    done
    review_needed
    mastered
}

enum DevicePlatform {
    ios
    android
    web
    desktop
}

enum NotificationChannel {
    socket
    fcm
    email
    sms
    in_app
}

enum NotificationType {
    achievement
    reminder
    system
    social
    assignment
    streak
    parent_child
}

enum AssignmentStatus {
    draft
    published
    completed
    overdue
    submitted
    graded
}

enum QuestionType {
    multiple_choice
    fill_blank
    true_false
    matching
    ordering
    essay
    audio_response
}

enum ContentStatus {
    draft
    review
    approved
    published
    archived
}

enum RewardType {
    digital
    physical
    screen_time
    activity
}

enum DifficultyLevel {
    beginner
    elementary
    intermediate
    upper_intermediate
    advanced
    expert
}

enum ClassStatus {
    scheduled   // Đã lên lịch
    ongoing     // Đang diễn ra
    completed   // Đã hoàn thành
    cancelled   // Đã hủy
    postponed   // Hoãn lại
}

enum ClassType {
    online      // Trực tuyến
    offline     // Tại trung tâm
    hybrid      // Kết hợp
}

enum EnrollmentStatus {
    pending     // Chờ xác nhận
    active      // Đang học
    completed   // Hoàn thành
    dropped     // Bỏ học
    suspended   // Tạm ngưng
}

// ===================== MODELS =====================
model KnowledgeDocument {
  id           String   @id @default(uuid())
  title        String
  content      String
  embedding    String
  documentType String
  source       String
  createdAt    DateTime @default(now())

  @@map("knowledge_documents")
}

model User {
    id           String       @id @default(uuid())
    email        String?      @unique
    phone        String?      @unique
    passwordHash String?
    role         UserRole     @default(student)
    status       Status       @default(active)
    provider     AuthProvider @default(local)
    providerId   String?

    // Thông tin cá nhân chi tiết
    firstName      String?
    lastName       String?
    displayName    String?
    gender         Gender?
    dob            DateTime?
    nationality    String?
    nativeLanguage LanguageCode?
    avatarUrl      String?
    bio            String?

    // Cài đặt hệ thống
    language LanguageCode? @default(en)
    timezone TimezoneCode? @default(Asia_Ho_Chi_Minh)

    // Thông tin xác thực
    lastLoginAt      DateTime?
    lastActiveAt     DateTime?
    emailVerified    Boolean   @default(false)
    phoneVerified    Boolean   @default(false)
    twoFactorEnabled Boolean   @default(false)

    // Cài đặt và tùy chọn
    preferences          Json?
    privacySettings      Json?
    notificationSettings Json?
    parentalConsent      Boolean?

    // Metadata
    profileCompleteness Int      @default(0)
    isOnline            Boolean  @default(false)
    createdAt           DateTime @default(now())
    updatedAt           DateTime @updatedAt

    // Relations
    Profile          Profile?
    Progress         Progress[]
    Attempts         Attempt[]
    RefreshToken     RefreshToken[]
    DeviceTokens     DeviceToken[]
    Notifications    Notification[]
    UserStats        UserStats?
    UserBadges       UserBadge[]
    LeaderboardEntry LeaderboardEntry[]

    // Parent-Child relations
    parentRelations ParentChild[] @relation("ParentChildParent")
    childRelations  ParentChild[] @relation("ParentChildChild")

    // Course and Class relations
    coursesCreated    Course[]           @relation("CourseInstructor")
    courseEnrollments CourseEnrollment[]

    // Teacher-Student relations
    classroomsTeaching    Classroom[]            @relation("TeacherClassrooms")
    classroomsSessions     ClassroomSession[]
    sessionAttendance      SessionAttendance[]
    classroomsStudying    ClassroomStudent[]
    assignmentsCreated    Assignment[]           @relation("TeacherAssignments")
    assignmentSubmissions AssignmentSubmission[]

    // Social features
    friendsInitiated Friendship[] @relation("FriendshipInitiator")
    friendsReceived  Friendship[] @relation("FriendshipReceiver")

    // Communication
    messagesFrom Message[] @relation("MessageFrom")
    messagesTo   Message[] @relation("MessageTo")

    // Custom content
    createdContent Content[] @relation("ContentCreator")

    // Rewards and achievements
    customRewards CustomReward[] @relation("ParentRewards")
    rewardClaims  RewardClaim[]

    // Daily quests
    questProgress QuestProgress[]

    // Security
    securityLogs  SecurityLog[]
    loginSessions LoginSession[]

    // Podcast & Listening Practice
    podcastsCreated       Podcast[]                @relation("PodcastAuthor")
    podcastProgress       UserPodcastProgress[]    @relation("UserPodcastProgress")
    podcastAttempts       PodcastActivityAttempt[] @relation("UserPodcastAttempts")
    podcastRatings        PodcastRating[]          @relation("UserPodcastRatings")
    podcastComments       PodcastComment[]         @relation("UserPodcastComments")
    playlists             Playlist[]               @relation("UserPlaylists")

    @@index([status])
    @@index([provider, providerId])
    @@index([lastActiveAt])
    @@index([role])
    @@index([email])
    @@index([phone])
}

model Course {
  id              String          @id @default(uuid())
  title           String
  description     String?
  orderNo         Int?
  difficulty      DifficultyLevel @default(beginner)
  estimatedHours  Float?          // Tổng giờ ước tính để hoàn tất course (tính bằng giờ)
  imageUrl        String?
  tags            String[]
  isPublished     Boolean         @default(false)
  prerequisites   String[]

  // Details
  instructorId    String
  price           Float?          @default(0)
  currency        String?         @default("VND")
  maxStudents     Int?            @default(20)
  language        LanguageCode    @default(vi)

  // Content metrics (tùy chọn)
  totalLessons    Int?            @default(0)
  totalDuration   Int?            @default(0) // phút

  // Meta
  rating          Float?
  totalRatings    Int             @default(0)
  enrollmentCount Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  instructor        User                @relation("CourseInstructor", fields: [instructorId], references: [id], onDelete: Cascade)
  lessons           Lesson[]
  courseRatings     CourseRating[]
  courseEnrollments CourseEnrollment[]
  classrooms        Classroom[]         // 1 course → nhiều classroom

  @@index([instructorId])
  @@index([orderNo])
  @@index([difficulty])
  @@index([isPublished])
  @@index([price])
}

model CourseEnrollment {
  id           String           @id @default(uuid())
  courseId     String
  studentId    String
  status       EnrollmentStatus @default(pending)
  enrolledAt   DateTime         @default(now())
  completedAt  DateTime?
  droppedAt    DateTime?

  // Payment (tuỳ chọn)
  amountPaid   Float?           @default(0)
  paymentId    String?

  // Progress
  progress     Float            @default(0)  // 0..100 %
  lastActivity DateTime?

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
  @@index([studentId])
  @@index([status])
  @@index([enrolledAt])
}



model Room {
  id          String  @id @default(uuid())
  name        String
  code        String  @unique       // VD: A101, B205
  location    String?
  capacity    Int     @default(30)
  description String?

  equipment   Json?
  facilities  Json?
  isActive    Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions    ClassroomSession[]   // phòng gán cho các buổi

  @@index([code])
  @@index([isActive])
}

// ===================== ORIGINAL MODELS (MODIFIED) =====================

model CourseRating {
    id        String   @id @default(uuid())
    courseId  String
    userId    String
    rating    Int // 1-5 sao
    comment   String?
    createdAt DateTime @default(now())

    course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

    @@unique([courseId, userId])
    @@index([courseId])
}

model Lesson {
    id            String          @id @default(uuid())
    courseId      String
    title         String
    description   String?
    orderNo       Int
    difficulty    DifficultyLevel @default(beginner)
    estimatedTime Int?
    isLocked      Boolean         @default(true)
    objectives    String[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    course        Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
    activities    Activity[]
    lessonDetails LessonDetail[]

    @@unique([courseId, orderNo])
    @@index([courseId, orderNo])
    @@index([isLocked])
}

model LessonDetail {
    id       String @id @default(uuid())
    lessonId String
    type     String
    content  Json
    orderNo  Int

    lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

    @@index([lessonId])
    @@index([lessonId, orderNo])
}

model Activity {
  id         String         @id @default(uuid())
  lessonId   String
  type       ActivityType
  orderNo    Int
  title      String

  // === Nguồn sự thật cho mọi loại activity ===
  // Lưu JSONB (Postgres): payload phụ thuộc 'type'
  content    Json

  // Cấu hình chung
  timeLimit    Int?
  maxAttempts  Int?
  passingScore Int?
  difficulty   DifficultyLevel @default(beginner)
  points       Int              @default(10)

  // Metadata nhẹ (tùy chọn)
  instructions String?
  hints        String[] @default([]) // gọn hơn Json? khi chỉ là list text
  mediaUrls    String[] @default([]) // dùng text[] nếu chỉ URL

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  lesson   Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  progress Progress[]
  attempts Attempt[]

  @@unique([lessonId, orderNo])
  @@index([lessonId, orderNo])
  @@index([type])
  @@index([difficulty])
}
model Question {
    id            String       @id @default(uuid())
    activityId    String
    type          QuestionType
    question      String
    options       Json?
    correctAnswer String
    explanation   String?
    points        Int          @default(1)
    orderNo       Int
    mediaUrl      String?


    @@index([activityId])
    @@index([activityId, orderNo])
}

// ===================== ORIGINAL MODELS (UNCHANGED) =====================

model RefreshToken {
    id         String    @id
    userId     String
    user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    deviceId   String?
    expiresAt  DateTime
    createdAt  DateTime  @default(now())
    revokedAt  DateTime?
    lastUsedAt DateTime?

    @@index([userId])
    @@index([deviceId])
}

model LoginSession {
    id           String   @id @default(uuid())
    userId       String
    deviceInfo   Json?
    ipAddress    String?
    location     String?
    userAgent    String?
    isActive     Boolean  @default(true)
    expiresAt    DateTime
    createdAt    DateTime @default(now())
    lastActiveAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([isActive])
}

model SecurityLog {
    id        String   @id @default(uuid())
    userId    String
    action    String
    ipAddress String?
    userAgent String?
    location  String?
    metadata  Json?
    createdAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([action])
    @@index([createdAt])
}

model Profile {
    id          String    @id @default(uuid())
    userId      String    @unique
    displayName String?
    avatarUrl   String?
    dob         DateTime?
    guardianId  String?

    // Thông tin học tập
    currentLevel   String?
    learningGoals  Json?
    studyStreak    Int     @default(0)
    totalStudyTime Int     @default(0)

    // Cài đặt học tập cá nhân
    dailyGoalMinutes Int?
    reminderTimes    Json?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Progress {
    id            String        @id @default(uuid())
    userId        String
    activityId    String
    state         ProgressState @default(not_started)
    score         Int?
    bestScore     Int?
    timeSpentSec  Int           @default(0)
    attemptsCount Int           @default(0)

    // Chi tiết tiến trình
    lastQuestionIndex Int?
    strengths         Json?
    weaknesses        Json?

    createdAt DateTime @default(now())
    updatedAt DateTime @default(now())

    user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

    @@unique([userId, activityId])
    @@index([userId, updatedAt])
    @@index([state])
}

model Attempt {
    id         String  @id @default(uuid())
    userId     String
    activityId String
    score      Int?
    maxScore   Int?
    timeSpent  Int?
    detail     Json?
    feedback   String?

    // Phân tích chi tiết
    correctAnswers Int?
    totalQuestions Int?
    averageTime    Int?

    createdAt DateTime @default(now())

    user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

    @@index([userId, createdAt])
    @@index([activityId])
}


// ===================== CLASSROOM (COHORT) =====================
model Classroom {
  id          String       @id @default(uuid())
  courseId    String
  teacherId   String
  name        String
  description String?
  classCode   String       @unique
  isActive    Boolean      @default(true)
  maxStudents Int?

  // Thông tin thời gian của CẢ LỚP (khung chạy của cohort)
  periodStart DateTime     // Ngày bắt đầu lớp (theo lịch)
  periodEnd   DateTime     // Ngày kết thúc lớp (theo lịch)
  timezone    TimezoneCode @default(Asia_Ho_Chi_Minh)

  // Quy mô giờ học của lớp
  plannedHours         Float    // Tổng SỐ GIỜ học cần dạy cho lớp (ví dụ: 36 giờ)
  sessionDurationHours Float    // SỐ GIỜ mỗi buổi (ví dụ: 1.5 giờ/buổi)
  plannedSessions      Int?     // Số buổi dự kiến (có thể = plannedHours / sessionDurationHours, lưu để tiện query)

  // Cài đặt khác
  settings Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime?

  // Relations
  course        Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher       User               @relation("TeacherClassrooms", fields: [teacherId], references: [id], onDelete: Cascade)
  students      ClassroomStudent[]
  assignments   Assignment[]
  announcements Announcement[]
  slots         ClassroomSlot[]    // Khung giờ tuần (pattern)
  sessions      ClassroomSession[] // Các BUỔI sinh ra từ pattern hoặc tạo tay

  @@index([courseId])
  @@index([teacherId])
  @@index([classCode])
  @@index([isActive])
  @@index([periodStart])
  @@index([periodEnd])
}

// ===================== WEEKLY SLOTS (KHUNG GIỜ) =====================
// Mỗi slot = 1 ca cố định trong tuần (VD: Tue 18:30-20:00)
// Lưu giờ theo phút từ 00:00 để không cần kiểu TIME
model ClassroomSlot {
  id                 String   @id @default(uuid())
  classroomId        String
  dayOfWeek          Weekday
  startMinuteOfDay   Int      // ví dụ 18:30 -> 18*60+30 = 1110
  endMinuteOfDay     Int      // ví dụ 20:00 -> 1200
  isActive           Boolean  @default(true)

  // Nếu muốn khác duration từng slot (tuỳ chọn)
  sessionDurationHours Float? // nếu null → dùng Classroom.sessionDurationHours

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@index([classroomId])
  @@index([dayOfWeek])
}

// ===================== CLASSROOM SESSIONS (BUỔI HỌC) =====================
model ClassroomSession {
  id            String        @id @default(uuid())
  classroomId   String
  instructorId  String

  title         String
  description   String?

  // Thời điểm thực tế của buổi (UTC)
  startTime     DateTime
  endTime       DateTime
  timezone      TimezoneCode  @default(Asia_Ho_Chi_Minh)

  // Thời lượng buổi (giờ) – thực tế, có thể khác pattern nếu dời lịch
  durationHours Float

  // Hình thức
  type          SessionType   @default(offline)
  status        SessionStatus @default(scheduled)
  maxStudents   Int?

  // Địa điểm/meeting
  roomId        String?
  meetingUrl    String?
  location      String?

  // Nội dung
  agenda        Json?
  materials     Json?
  homework      Json?

  // Meta
  notes         String?
  recordingUrl  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  classroom  Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  instructor User      @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  attendance SessionAttendance[]
  room       Room?     @relation(fields: [roomId], references: [id])

  @@index([classroomId])
  @@index([instructorId])
  @@index([startTime])
  @@index([endTime])
}


model SessionAttendance {
  id           String   @id @default(uuid())
  sessionId    String
  studentId    String
  status       String   @default("present") // present, absent, late, excused
  checkInTime  DateTime?
  checkOutTime DateTime?
  notes        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  session ClassroomSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
  @@index([status])
}



model ClassroomStudent {
    classroomId String
    studentId   String
    joinedAt    DateTime @default(now())
    isActive    Boolean  @default(true)

    // Metadata
    notes     String?
    groupName String?

    classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
    student   User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

    @@id([classroomId, studentId])
    @@index([studentId])
}

model Assignment {
    id           String  @id @default(uuid())
    teacherId    String
    classroomId  String
    title        String
    description  String?
    instructions String?

    // Cấu hình bài tập
    dueDate     DateTime?
    totalPoints Int       @default(100)
    timeLimit   Int?
    maxAttempts Int       @default(1)

    // Trạng thái
    status      AssignmentStatus @default(draft)
    isPublished Boolean          @default(false)

    // Targeting
    assignedTo String[]

    // Content
    activities    Json
    customContent Json?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    teacher     User                   @relation("TeacherAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
    classroom   Classroom              @relation(fields: [classroomId], references: [id], onDelete: Cascade)
    submissions AssignmentSubmission[]

    @@index([teacherId])
    @@index([classroomId])
    @@index([status])
    @@index([dueDate])
}

model AssignmentSubmission {
    id           String @id @default(uuid())
    assignmentId String
    studentId    String

    // Submission details
    submittedAt DateTime  @default(now())
    score       Int?
    feedback    String?
    gradedAt    DateTime?

    // Content
    answers      Json
    timeSpent    Int?
    attemptCount Int  @default(1)

    // Status
    isLate Boolean @default(false)
    status String  @default("submitted")

    assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
    student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

    @@unique([assignmentId, studentId, attemptCount])
    @@index([assignmentId])
    @@index([studentId])
}

model Announcement {
    id          String   @id @default(uuid())
    classroomId String
    title       String
    content     String
    priority    String   @default("normal")
    targetAll   Boolean  @default(true)
    targetIds   String[]

    // Media attachments
    attachments Json?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

    @@index([classroomId])
    @@index([priority])
    @@index([createdAt])
}

// ===================== PARENT-CHILD FEATURES =====================

model ParentChild {
    parentId  String
    childId   String
    createdAt DateTime @default(now())

    // Cài đặt giám sát
    canViewProgress Boolean @default(true)
    canSetGoals     Boolean @default(true)
    canControlTime  Boolean @default(true)
    dailyTimeLimit  Int?
    bedtimeStart    String?
    bedtimeEnd      String?

    // Cài đặt nội dung
    allowedActivities String[]
    blockedContent    String[]
    maxDifficulty     DifficultyLevel?

    parent User @relation("ParentChildParent", fields: [parentId], references: [id], onDelete: Cascade)
    child  User @relation("ParentChildChild", fields: [childId], references: [id], onDelete: Cascade)

    @@id([parentId, childId])
    @@index([childId])
}

model CustomReward {
    id          String     @id @default(uuid())
    parentId    String
    childId     String
    title       String
    description String?
    type        RewardType
    cost        Int
    imageUrl    String?
    isActive    Boolean    @default(true)

    // Cấu hình phần thưởng
    metadata Json?

    createdAt DateTime @default(now())

    parent User          @relation("ParentRewards", fields: [parentId], references: [id], onDelete: Cascade)
    claims RewardClaim[]

    @@index([parentId])
    @@index([childId])
}

model RewardClaim {
    id        String   @id @default(uuid())
    rewardId  String
    childId   String
    status    String   @default("pending")
    claimedAt DateTime @default(now())

    reward CustomReward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
    child  User         @relation(fields: [childId], references: [id], onDelete: Cascade)

    @@index([rewardId])
    @@index([childId])
    @@index([status])
}

// ===================== DEVICE AND NOTIFICATIONS =====================

model DeviceToken {
    id         String         @id @default(uuid())
    userId     String
    token      String         @unique
    platform   DevicePlatform
    deviceId   String?
    deviceName String?
    appVersion String?
    osVersion  String?
    lastSeenAt DateTime?
    isActive   Boolean        @default(true)
    createdAt  DateTime       @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, platform])
    @@index([token])
}

model Notification {
    id      String              @id @default(uuid())
    userId  String
    type    NotificationType
    title   String
    body    String?
    data    Json?
    channel NotificationChannel

    // Targeting và scheduling
    targetRole   UserRole?
    scheduledFor DateTime?

    // Status
    readAt    DateTime?
    clickedAt DateTime?
    delivered Boolean   @default(false)

    // Metadata
    priority  String  @default("normal")
    actionUrl String?
    imageUrl  String?

    createdAt DateTime  @default(now())
    expiresAt DateTime?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, createdAt])
    @@index([type])
    @@index([delivered])
    @@index([scheduledFor])
}

// ===================== GAMIFICATION =====================

model UserStats {
    userId        String    @id
    xp            Int       @default(0)
    level         Int       @default(1)
    streakDays    Int       @default(0)
    longestStreak Int       @default(0)
