generator client {
    provider = "prisma-client-js"
    output   = "../../../node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ============ ENUMS ============
enum UserRole {
    student
    parent
    teacher
    admin
}

enum Status {
    active
    inactive
    banned
    pending
}

enum AuthProvider {
    local
    google
    facebook
    apple
}

enum Gender {
    male
    female
    other
}

enum LanguageCode {
    en
    vi
    ko
    jp
    zh
    fr
}

enum TimezoneCode {
    Asia_Ho_Chi_Minh
    Asia_Tokyo
    Asia_Seoul
    America_New_York
    Europe_London
}

enum ActivityType {
    vocab
    pronunciation
    listening
    speaking
    mini_game
}

// ✅ Thêm enum cho Progress.state
enum ProgressState {
    not_started
    in_progress
    done
}

// ============ MODELS ============

model User {
    id            String        @id @default(uuid())
    email         String?       @unique
    phone         String?       @unique
    username      String?       @unique
    passwordHash  String?
    role          UserRole      @default(student)
    status        Status        @default(active)
    provider      AuthProvider  @default(local)
    providerId    String?
    firstName     String?
    lastName      String?
    gender        Gender?
    dob           DateTime?
    avatarUrl     String?
    bio           String?
    language      LanguageCode?
    timezone      TimezoneCode?
    lastLoginAt   DateTime?
    lastActiveAt  DateTime?
    emailVerified Boolean       @default(false)
    phoneVerified Boolean       @default(false)
    preferences   Json?
    createdAt     DateTime      @default(now())
    updatedAt     DateTime      @updatedAt

    Profile      Profile?
    Progress     Progress[]
    Attempts     Attempt[]
    RefreshToken RefreshToken[]

    @@index([status])
    @@index([provider, providerId])
    @@index([lastActiveAt])
}

model RefreshToken {
    id     String @id
    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    expiresAt DateTime
    createdAt DateTime  @default(now())
    revokedAt DateTime?

    @@index([userId])
}

model Profile {
    id          String    @id @default(uuid())
    userId      String    @unique
    displayName String?
    avatarUrl   String?
    dob         DateTime?
    guardianId  String? // parent user id (nếu là học sinh)

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Nếu muốn enforce guardian là một User tồn tại:
    // guardian   User?   @relation("GuardianProfile", fields: [guardianId], references: [id])
    // @@index([guardianId])
}

model Course {
    id          String  @id @default(uuid())
    title       String
    description String?
    orderNo     Int

    lessons Lesson[]

    @@unique([orderNo]) // nếu bạn muốn một thứ tự course toàn cục không trùng
    @@index([orderNo])
}

model Lesson {
    id          String  @id @default(uuid())
    courseId    String
    title       String
    description String?
    orderNo     Int

    course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
    activities Activity[]

    // ✅ Thứ tự lesson trong cùng một course phải duy nhất
    @@unique([courseId, orderNo])
    @@index([courseId, orderNo])
}

model Activity {
    id       String       @id @default(uuid())
    lessonId String
    type     ActivityType
    orderNo  Int
    content  Json

    lesson   Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
    progress Progress[]
    attempts Attempt[]

    // ✅ Thứ tự activity trong cùng một lesson phải duy nhất
    @@unique([lessonId, orderNo])
    @@index([lessonId, orderNo])
}

model Progress {
    id           String        @id @default(uuid())
    userId       String
    activityId   String
    state        ProgressState @default(not_started) // ✅ enum hóa state
    score        Int?
    timeSpentSec Int           @default(0)
    updatedAt    DateTime      @default(now())

    user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

    @@unique([userId, activityId]) // mỗi user – 1 record progress/hoạt động
    @@index([userId, updatedAt])
}

model Attempt {
    id         String   @id @default(uuid())
    userId     String
    activityId String
    score      Int?
    detail     Json?
    createdAt  DateTime @default(now())

    user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

    @@index([userId, createdAt])
}
