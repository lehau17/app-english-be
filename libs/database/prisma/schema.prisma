  attemptCount    Int       @default(0)
  lastAttemptedAt DateTime?

  // Adaptivity data
  wasSkipped       Boolean @default(false)
  skipReason       String?
  recommendedNext  String[] // Activity IDs for next steps
  adaptivityReason String? // Why this step was chosen

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  learningPath    LearningPath      @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  activityVariant ActivityVariant?  @relation(fields: [variantId], references: [id], onDelete: SetNull)
  skillProgress   SkillProgress[]   @relation("StepSkillProgress")

  @@unique([learningPathId, orderNo])
  @@index([learningPathId, status])
  @@index([variantId])
  @@index([learningPathId, orderNo])
}

enum StepStatus {
  pending
  in_progress
  completed
  skipped
  failed
}

// Skill progress tracking with SRS
model SkillProgress {
  id String @id @default(uuid())

  userId String
  skill  String // "vocabulary", "grammar", "listening", etc.

  // SRS algorithm (SM-2)
  easeFactor  Float @default(2.5) // 1.3 - 2.5+
  interval    Int   @default(1) // days
  repetitions Int   @default(0) // consecutive correct count

  // Performance stats
  correctCount   Int @default(0)
  incorrectCount Int @default(0)
  totalAttempts  Int @default(0)

  // Proficiency level
  level      String   @default("beginner") // beginner, intermediate, advanced
  confidence Float    @default(0.5) // 0.0 - 1.0
  masteryScore Float  @default(0) // 0 - 100

  // Timestamps
  lastReviewAt DateTime  @default(now())
  nextReviewAt DateTime // When to review next
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  steps LearningPathStep[] @relation("StepSkillProgress")

  @@unique([userId, skill])
  @@index([userId])
  @@index([userId, nextReviewAt])
  @@index([userId, skill])
}

// AI-generated activity variants storage
model ActivityVariant {
  id String @id @default(uuid())

  // Source
  baseActivityId  String? // Original activity it's based on (if any)
  activityType    ActivityType
  difficulty      DifficultyLevel
  skill           String // Primary skill targeted

  // Content
  title       String
  description String?
  content     Json // Full activity content (questions, answers, media URLs)
  mediaUrls   String[]

  // Generation metadata
  promptTemplateId String? // Which prompt generated this
  generationParams Json? // Parameters used for generation
  aiModel          String? // "gemini-2.5-flash", etc.

  // Quality tracking
  usageCount    Int     @default(0)
  averageScore  Float?
  feedbackCount Int     @default(0)
  isApproved    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  steps            LearningPathStep[]
  promptTemplate   PromptTemplate?    @relation(fields: [promptTemplateId], references: [id], onDelete: SetNull)

  @@index([activityType, difficulty])
  @@index([skill])
  @@index([promptTemplateId])
  @@index([isApproved, usageCount])
}

// Prompt templates for AI activity generation
model PromptTemplate {
  id String @id @default(uuid())

  name        String @unique
  description String?

  // Template content
  systemPrompt String @db.Text
  userPrompt   String @db.Text

  // Configuration
  activityType ActivityType
  difficulty   DifficultyLevel?
  skill        String?

  // Model settings
  modelName   String  @default("gemini-2.5-flash")
  temperature Float   @default(0.7)
  maxTokens   Int     @default(2048)
  parameters  Json? // Additional parameters

  // Metadata
  version    Int     @default(1)
  isActive   Boolean @default(true)
  usageCount Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  variants ActivityVariant[]

  @@index([activityType])
  @@index([isActive])
}

// Audit trail for learning path events
model LearningPathEvent {
  id String @id @default(uuid())

  learningPathId String
  eventType      LearningPathEventType
  metadata       Json? // Event-specific data

  createdAt DateTime @default(now())

  // Relations
  learningPath LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)

  @@index([learningPathId, createdAt])
  @@index([eventType])
}

enum LearningPathEventType {
  created
  step_added
  step_completed
  step_skipped
  adapted // Path adapted based on performance
  completed
  abandoned
}

model StudySession {
  id String @id @default(uuid())

  userId String

  // Session data

  startTime DateTime @default(now())

  endTime DateTime?

  durationMinutes Int?

  // Activities in this session

  activitiesCompleted Int @default(0)

  xpEarned Int @default(0)

  // Performance

  averageScore Float?

  streakMaintained Boolean @default(false)

  // Context

  devicePlatform DevicePlatform?

  location String?

  @@index([userId])
  @@index([startTime])
  @@index([durationMinutes])
}

model Recommendation {
  id String @id @default(uuid())

  userId String

  type String

  title String

  description String?

  // Recommendation data

  confidence Float

  reasoning String?

  targetData Json

  // User interaction

  viewed Boolean @default(false)

  clicked Boolean @default(false)

  dismissed Boolean @default(false)

  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([expiresAt])
  @@index([viewed, clicked, dismissed])
}

// ===================== AI SPEAKING PRACTICE =====================

model AiSpeakingSession {
  id String @id @default(uuid())

  userId String

  conversationId String @default(uuid())

  topic String?

  goal String?

  state AiSpeakingSessionState @default(pending)

  maxTurns Int @default(8)

  turnCount Int @default(0)

  targetDifficulty DifficultyLevel @default(beginner)

  currentDifficulty DifficultyLevel?

  silenceWarnings Int @default(0)

  offTopicWarnings Int @default(0)

  config Json?

  metadata Json?

  analytics Json?

  summary String?

  summaryPayload Json?

  startedAt DateTime @default(now())

  lastActivityAt DateTime @default(now())

  endedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  turns AiSpeakingTurn[]

  @@index([userId, createdAt])
  @@index([userId, conversationId])
  @@index([state, lastActivityAt])
  @@map("ai_speaking_sessions")
}

model AiSpeakingTurn {
  id String @id @default(uuid())

  sessionId String

  turnIndex Int

  state AiSpeakingTurnStatus @default(pending)

  aiPrompt String?

  aiAudioUrl String?

  userTranscript String?

  userAudioUrl String?

  userDurationSec Int?

  metrics Json?

  evaluation Json?

  pronunciationFeedback Json?

  suggestions String[] @default([])

  score Int?

  relevanceScore Float?

  silenceDetected Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  session AiSpeakingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  segments AiSpeakingTurnSegment[]

  @@unique([sessionId, turnIndex])
  @@index([sessionId])
  @@index([state, createdAt])
  @@map("ai_speaking_turns")
