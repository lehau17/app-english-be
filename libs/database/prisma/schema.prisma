  turnId String

  role AiSpeakingTurnRole

  orderNo Int @default(0)

  transcript String?

  audioUrl String?

  durationSec Int?

  payload Json?

  createdAt DateTime @default(now())

  turn AiSpeakingTurn @relation(fields: [turnId], references: [id], onDelete: Cascade)

