  active

  inactive

  banned

  pending

  suspended
}

enum AttemptStatus {
  in_progress // User đang làm

  submitted // User đã nộp (chấm điểm xong)

  completed // Đã xem lại/kết thúc
}

enum SessionStatus {
  scheduled

  ongoing

  completed

  cancelled

  postponed
}

enum MakeupRequestStatus {
