    currentLevel    : String?
    learningGoals   : Json?
    studyStreak     : Int
    totalStudyTime  : Int
    dailyGoalMinutes: Int?
    reminderTimes   : Json?
  }

  class RefreshToken {
    id         : String
    userId     : String
    deviceId   : String?
    expiresAt  : DateTime
    createdAt  : DateTime
    revokedAt  : DateTime?
    lastUsedAt : DateTime?
  }

  class LoginSession {
    id          : String
    userId      : String
    deviceInfo  : Json?
    ipAddress   : String?
    location    : String?
    userAgent   : String?
    isActive    : Boolean
    expiresAt   : DateTime
    createdAt   : DateTime
    lastActiveAt: DateTime
  }

  class SecurityLog {
    id         : String
    userId     : String
    action     : String
    ipAddress  : String?
    userAgent  : String?
    location   : String?
    metadata   : Json?
    createdAt  : DateTime
  }

  class PasswordResetToken {
    id         : String
    userId     : String
    tokenHash  : String
    expiresAt  : DateTime
    usedAt     : DateTime?
    createdAt  : DateTime
  }

  class DeviceToken {
    id         : String
    userId     : String
