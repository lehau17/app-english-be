' ===================== USER & AUTH =====================
package "User & Auth" {

  class User {
    id                : String
    email             : String?
    phone             : String?
    passwordHash      : String?
    role              : UserRole
    status            : Status
    provider          : AuthProvider
    providerId        : String?
    firstName         : String?
    lastName          : String?
