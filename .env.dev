# ========================================
# Development Environment Configuration
# ========================================
# Chỉ cần 3 services cơ bản: Postgres, Redis, Redpanda

# ========================================
# Database Configuration
# ========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=english_learning
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/english_learning?schema=public

# ========================================
# Redis Configuration
# ========================================
REDIS_PORT=6379
# Development không cần password
REDIS_URL=redis://localhost:6379

# ========================================
# Kafka/Redpanda Configuration
# ========================================
KAFKA_BROKERS=localhost:19092

# ========================================
# Backend API Configuration
# ========================================
CLIENT_API_PORT=3334
NODE_ENV=development

# ========================================
# JWT Configuration
# ========================================
JWT_SECRET=your-dev-secret-key-change-in-production
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
