# Production Environment Configuration
# Copy this file to .env on your VPS and update with your production values

# ========================================
# Database Configuration
# ========================================
DATABASE_URL=postgresql://postgres:CHANGE_THIS_PASSWORD@postgres:5432/english_learning
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=english_learning
POSTGRES_PORT=5432

# ========================================
# JWT Configuration
# ========================================
JWT_SECRET=CHANGE_THIS_TO_VERY_LONG_RANDOM_STRING_IN_PRODUCTION
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ========================================
# Kafka Configuration
# ========================================
KAFKA_BROKERS=redpanda:9092

# ========================================
# SMTP Configuration (for notifications)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
FROM=your-email@gmail.com

# ========================================
# S3/MinIO Configuration
# ========================================
S3_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=CHANGE_THIS_IN_PRODUCTION
S3_BUCKET_NAME=english-learning-bucket
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=CHANGE_THIS_IN_PRODUCTION
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ========================================
# API Configuration
# ========================================
CLIENT_API_PORT=3334
API_BASE_URL=http://your-domain-or-ip.com:3334

# ========================================
# Google Cloud Configuration
# ========================================
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_KEY_FILE=/app/gcloud-key.json

# ========================================
# Gemini AI Configuration
# ========================================
GEMINI_API_KEY=your-gemini-api-key

# ========================================
# AI Speaking Configuration
# ========================================
AI_SPEAKING_TTS_USE_HTTP=true
AI_SPEAKING_TTS_HTTP_URL=http://piper-tts:10200
AI_SPEAKING_TTS_VOICE=en_US-lessac-medium
AI_SPEAKING_ASR_WS_URL=ws://vosk-asr:2700
AI_SPEAKING_ASR_AUDIO_FORMAT=pcm16
AI_SPEAKING_ASR_SAMPLE_RATE=16000
AI_SPEAKING_HEALTH_SKIP=false
AI_SPEAKING_HEALTH_TIMEOUT_MS=3000

# ========================================
# Docker Configuration (for deployment)
# ========================================
DOCKER_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

# ========================================
# Redis Configuration
# ========================================
REDIS_PORT=6379

# ========================================
# TTS/ASR Ports
# ========================================
PIPER_PORT=10200
VOSK_PORT=2700
